/*
 * logging.config — observability + resume hardening, always included.
 *
 * Goals (from the brief): "log and handle exceptions exceptionally well so we can
 * just resume, fetch new data, redo some analysis." Concretely:
 *
 *  - cache='lenient'  : hashes inputs by size+path not full content/timestamp, so
 *                       -resume survives object-store/networked-FS timestamp churn.
 *                       This is THE setting that makes resume reliable in the cloud.
 *  - rich trace       : every task's status, exit code, attempt, host, peak RSS,
 *                       %CPU and realtime -> trace.txt for post-hoc triage.
 *  - weblog (opt-in)  : POST live events to a dashboard/Seqera-style monitor.
 *  - failed-task logs  : on failure the task's .command.* are retained (no cleanup)
 *                       so the exact command + stderr can be inspected and re-run.
 */

params {
    weblog_url = null        // set to POST run events to a monitoring endpoint
}

// reliable resume everywhere (HPC shared FS, S3/GCS/R2 object stores, k8s PVC)
process.cache = 'lenient'

// keep work dirs after a run so failed tasks can be inspected & resumed
cleanup = false

trace {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/trace.txt"
    fields    = 'task_id,hash,native_id,name,status,exit,attempt,submit,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}

weblog {
    enabled = params.weblog_url ? true : false
    url     = params.weblog_url ?: ''
}

// surface a one-line, copy-pasteable diagnosis for any failed task
notification { enabled = false }   // wire to email/Slack later via params
