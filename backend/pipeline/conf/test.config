/*
 * test.config — tiny smoke test that exercises the full DAG quickly.
 *
 *   nextflow run main.nf -profile test,apptainer
 *
 * Uses a 2-row samplesheet of small public runs and clamps resources so it fits
 * on a single modest node. NOT a correctness benchmark — just "does it wire up".
 */

params {
    input  = "${projectDir}/assets/test_samplesheet.csv"
    outdir = 'results_test'

    max_cpus   = 4
    max_memory = '12.GB'
    max_time   = '2.h'

    max_reads     = 200000   // subsample hard so assembly/quant finish in minutes
    min_identity  = 80.0
}

// keep the test single-node regardless of which executor profile is added
process {
    executor = 'local'
    withName:ENA_FETCH { maxRetries = 2 }
}
