/*
 * k8s.config — run on any Kubernetes cluster (cloud-agnostic; works on EKS/GKE/AKS
 * or an on-prem cluster). Most portable cloud option: no provider lock-in.
 *
 *   nextflow kuberun main.nf -profile k8s,apptainer \
 *       --input samplesheet.csv --outdir /mnt/argive/v2026.06
 *
 * Requires a ReadWriteMany PVC (the work + output volume) shared across pods.
 */
params {
    k8s_namespace   = 'argive'
    k8s_pvc         = 'argive-work'      // pre-created ReadWriteMany PersistentVolumeClaim
    k8s_mount       = '/mnt/argive'
}

process {
    executor = 'k8s'
    cache    = 'lenient'
}

k8s {
    namespace        = params.k8s_namespace
    storageClaimName = params.k8s_pvc
    storageMountPath = params.k8s_mount
    pullPolicy       = 'IfNotPresent'
    // fair-share + don't let one run hog the cluster
    computeResourceType = 'Job'
}

workDir = "${params.k8s_mount}/work"
