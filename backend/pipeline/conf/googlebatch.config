/*
 * googlebatch.config — run every task on Google Cloud Batch.
 *
 *   nextflow run main.nf -profile googlebatch \
 *       --input samplesheet.csv --outdir gs://argive-archive/v2026.06 \
 *       --google_project my-proj --google_location europe-north1 \
 *       -w gs://argive-work/scratch
 *
 * Outputs can still be mirrored to R2/Zenodo by the publishing stage; GCS is the
 * compute-local work + publish store here.
 */
params {
    google_project  = null       // REQUIRED
    google_location = 'europe-north1'
    google_spot     = true       // use Spot VMs for cost (tasks retry on preemption)
}

process {
    executor = 'google-batch'
    cache    = 'lenient'
}

google {
    project  = { params.google_project ?: { exit 1, 'googlebatch profile needs --google_project' }() }
    location = params.google_location
    batch {
        spot              = params.google_spot
        bootDiskSize      = '50.GB'
        maxSpotAttempts   = 3
    }
}
