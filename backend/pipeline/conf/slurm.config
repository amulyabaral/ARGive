/*
 * slurm.config — HPC executor profile.
 *
 * Tuned for Norwegian academic clusters (Sigma2/NRIS: Saga/Fram/Betzy) but
 * portable to any SLURM site. Adjust `queueSize`, `clusterOptions` (account!),
 * and partition `queue` names for your allocation.
 *
 *   nextflow run main.nf -profile slurm,apptainer --input ... --outdir ...
 */

process {
    executor = 'slurm'

    // REQUIRED on most academic clusters: set your project/account here or pass
    //   --slurm_account nnXXXXk  (wired below). Jobs are rejected without it.
    clusterOptions = { params.slurm_account ? "--account=${params.slurm_account}" : '' }

    // partition selection by size; rename to match your site's partitions
    queue = { task.memory >= 180.GB ? 'bigmem' : 'normal' }
}

params {
    slurm_account = null   // e.g. 'nn1234k' — pass with --slurm_account
}

executor {
    name            = 'slurm'
    queueSize       = 100          // max concurrent submitted jobs
    submitRateLimit = '20/1min'    // be polite to the scheduler
    pollInterval    = '30 sec'
    exitReadTimeout = '5 min'
}
