/*
 * apptainer.config — run every process inside a pinned container.
 *
 * Apptainer (formerly Singularity) is the HPC norm: rootless, image-as-file.
 * Container URIs are pinned per process in modules/local/*.nf via `container`.
 * Images are pulled once to `cacheDir` and reused across runs/jobs.
 */

apptainer {
    enabled    = true
    autoMounts = true
    // Pull/convert images here once. Point at shared project storage so every
    // compute node and every run reuses the same .sif files.
    cacheDir   = System.getenv('ARGIVE_APPTAINER_CACHE') ?: "${launchDir}/apptainer_cache"
    // pass through proxy/registry creds if the cluster needs them
    runOptions = '--cleanenv'
}

// Some sites only have `singularity` on PATH; Nextflow's apptainer engine calls
// the apptainer binary. If your cluster exposes singularity instead, swap the
// block above for `singularity { enabled = true; ... }` — the container URIs in
// the modules are OCI/docker refs and work with either engine.

// Bind common HPC scratch/work locations so DBs and reads are visible in-container.
env {
    APPTAINER_BINDPATH = System.getenv('APPTAINER_BINDPATH') ?: '/cluster,/work,/scratch'
}
