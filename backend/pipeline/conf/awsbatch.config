/*
 * awsbatch.config — run every task as an AWS Batch job.
 *
 *   nextflow run main.nf -profile awsbatch,r2 \
 *       --input samplesheet.csv --outdir s3://argive-archive/v2026.06 \
 *       --aws_queue argive-queue --aws_region eu-north-1 -w s3://argive-work/scratch
 *
 * Pairs naturally with Cloudflare R2 for durable output (add the `r2` profile):
 * AWS egress to R2 is free on R2's side, and R2 has zero egress for downloads.
 * Containers are the SAME OCI images the modules pin — Batch pulls them per job.
 */
params {
    aws_queue  = null            // REQUIRED: a Batch job queue backed by a compute env
    aws_region = 'eu-north-1'
}

process {
    executor = 'awsbatch'
    queue    = { params.aws_queue ?: { exit 1, 'awsbatch profile needs --aws_queue' }() }
}

aws {
    region = params.aws_region
    batch {
        // path to the AWS CLI inside the Batch container host AMI (ECS-optimized)
        cliPath        = '/usr/local/bin/aws'
        maxParallelTransfers = 8
        maxTransferAttempts  = 3
        delayBetweenAttempts = '15 sec'
        volumes        = '/scratch'
    }
}

// object-store work dirs change timestamps on staging; lenient caching keeps -resume sane
process.cache = 'lenient'
