/*
 * r2.config — use Cloudflare R2 as the S3-compatible store for --outdir (and
 * optionally -w work dir). Compose with any executor profile, e.g.
 *
 *   nextflow run main.nf -profile awsbatch,r2 --outdir s3://argive-archive/v2026.06
 *
 * R2 speaks the S3 API, so Nextflow's built-in S3 support works once we point the
 * client at the R2 endpoint and use path-style access. Credentials come from the
 * environment (do NOT commit them):
 *   export AWS_ACCESS_KEY_ID=<r2 access key>
 *   export AWS_SECRET_ACCESS_KEY=<r2 secret>
 *   export ARGIVE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
 *
 * Why R2: ~$0.015/GB-mo storage and ZERO egress — ideal for a public,
 * download-heavy archive of small derived artifacts.
 */
aws {
    region = 'auto'
    client {
        endpoint          = System.getenv('ARGIVE_R2_ENDPOINT')
        s3PathStyleAccess = true
    }
}

process.cache = 'lenient'
