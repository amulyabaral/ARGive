/*
 * ARGive reprocessing pipeline — top-level configuration.
 *
 * Profiles are composed on the command line, e.g.
 *     nextflow run main.nf -profile slurm,apptainer
 *     nextflow run main.nf -profile test,apptainer
 *
 * Nothing here assumes a workstation: the default executor is `local` only so a
 * smoke test can run anywhere, but real runs MUST add the `slurm` profile.
 */

manifest {
    name            = 'argive/reprocess'
    author          = 'ARGive Consortium'
    description      = 'Harmonized, normalized, concordance-scored resistome reprocessing of public metagenomes'
    homePage        = 'https://argive.org'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '2026.06.0'
}

params {
    // ---- I/O ----
    input   = null                     // samplesheet CSV (see assets/samplesheet.schema.json)
    outdir  = 'results'
    release = 'v2026.06'               // stamped into every record's _provenance

    // ---- reference databases (resolved on the cluster; see conf/databases.config) ----
    amrfinder_db = null                // AMRFinderPlus DB dir; null => use container's bundled DB
    card_json    = null                // CARD card.json for RGI load; null => container default
    resfinder_db = null                // ResFinder DB dir (KMA-indexed)
    singlem_metapackage = null         // SingleM metapackage; null => container default

    // ---- behaviour ----
    min_identity = 80.0                // drop hits below this %% identity at harmonize stage
    skip_assembly = false              // assembly-based tools need contigs; set true for reads-only quant
    max_reads   = null                 // optional subsample cap for huge runs (null = all)

    // ---- pinned tool/db versions, stamped verbatim into _provenance.tool_versions ----
    // These are the SOURCE OF TRUTH for the release. Bump => new release tag.
    versions = [
        amrfinderplus : '4.0.3',
        amrfinder_db  : '2026-04-01.1',
        rgi           : '6.0.3',
        card          : '4.0.0',
        resfinder     : '4.5.0',
        resfinder_db  : '2026-04-15',
        abricate      : '1.0.1',
        hamronize     : '1.1.4',
        singlem       : '1.0.0',
        fastp         : '0.24.0',
        megahit       : '1.2.9'
    ]

    // ---- resource ceilings (clamp per-process requests; override per cluster) ----
    max_cpus   = 32
    max_memory = '256.GB'
    max_time   = '72.h'

    // ---- misc ----
    publish_dir_mode = 'copy'
    validate_params  = true
    tracedir = "${params.outdir}/pipeline_info"
}

// helper used by conf/base.config to clamp requests to the ceilings above
def check_max(obj, type) {
    if (type == 'memory') {
        try { return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1 ? params.max_memory as nextflow.util.MemoryUnit : obj }
        catch (all) { return obj }
    } else if (type == 'time') {
        try { return obj.compareTo(params.max_time as nextflow.util.Duration) == 1 ? params.max_time as nextflow.util.Duration : obj }
        catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj as int, params.max_cpus as int) }
        catch (all) { return obj }
    }
}

// make helper visible to included configs
ext.check_max = this.&check_max

includeConfig 'conf/base.config'

profiles {
    standard   { process.executor = 'local' }
    slurm      { includeConfig 'conf/slurm.config' }
    apptainer  { includeConfig 'conf/apptainer.config' }
    singularity { includeConfig 'conf/apptainer.config' }   // alias
    test       { includeConfig 'conf/test.config' }
    debug      { dumpHashes = true; process.beforeScript = 'echo $HOSTNAME'; cleanup = false }
}

// reproducibility artifacts written next to results
timeline { enabled = true; file = "${params.tracedir}/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.tracedir}/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.tracedir}/trace.txt";     overwrite = true }
dag      { enabled = true; file = "${params.tracedir}/dag.html";      overwrite = true }
