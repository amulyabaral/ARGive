# Force LF for everything that executes on the (Linux) HPC. CRLF in a Nextflow
# script block or a Python/shell helper will break the in-container bash.
* text=auto eol=lf
*.nf      text eol=lf
*.config  text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.tsv     text eol=lf
*.csv     text eol=lf

# Binary/never-normalize
*.sif binary
*.gz  binary
*.bam binary
